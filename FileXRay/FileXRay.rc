LANGUAGE LANG_JAPANESE, SUBLANG_DEFAULT

IDD_FILEXRAY_PAGE DIALOGEX 0, 0, 227, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI"
BEGIN
	GROUPBOX        "ファイル", IDC_FILE_GROUP, 7, 7, 213, 43
	EDITTEXT        IDC_FILE_TYPE, 17, 20, 197, 21, ES_MULTILINE | ES_READONLY | ES_AUTOHSCROLL | WS_BORDER | WS_TABSTOP

	GROUPBOX        "ハッシュ", IDC_HASH_GROUP, 7, 55, 213, 135
	CONTROL         "MD5", IDC_HASH_MD5, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 17, 72, 42, 10
	CONTROL         "SHA1", IDC_HASH_SHA1, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 82, 72, 45, 10
	CONTROL         "CRC32", IDC_HASH_CRC32, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 147, 72, 52, 10
	CONTROL         "CRC64", IDC_HASH_CRC64, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 17, 86, 52, 10
	CONTROL         "SHA256", IDC_HASH_SHA256, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 82, 86, 62, 10
	PUSHBUTTON      "計算", IDC_HASH_START, 17, 102, 60, 14
	PUSHBUTTON      "コピー", IDC_HASH_COPY, 154, 102, 60, 14
	CONTROL         "", IDC_HASH_PROGRESS, "msctls_progress32", WS_BORDER, 17, 122, 197, 10
	LTEXT           "準備完了。", IDC_HASH_STATUS, 17, 136, 197, 8
	EDITTEXT        IDC_HASH_RESULT, 17, 148, 197, 34, ES_MULTILINE | ES_READONLY | ES_AUTOHSCROLL | ES_AUTOVSCROLL | WS_VSCROLL | WS_BORDER | WS_TABSTOP

	GROUPBOX        "拡張機能", IDC_EXTENSION_GROUP, 7, 194, 213, 18
END

STRINGTABLE
BEGIN
	IDS_PAGE_TITLE                 "FileXRay"
	IDS_HASH_STATUS_READY          "準備完了。"
	IDS_HASH_STATUS_CANCELED       "キャンセルされました。"
	IDS_HASH_STATUS_FAILED_FORMAT  "失敗しました: 0x%08lx"
	IDS_HASH_SELECT_ONE            "少なくとも 1 つのハッシュ アルゴリズムを選択してください。"
	IDS_HASH_STATUS_CALCULATING    "計算中..."
	IDS_HASH_STATUS_COMPLETE       "完了しました。"
	IDS_HASH_STATUS_TOO_LARGE      "完了しましたが、結果のテキストが大きすぎます。"
	IDS_FILETYPE_UNABLE_FORMAT     "ファイルを識別できません: 0x%08lx"
END
