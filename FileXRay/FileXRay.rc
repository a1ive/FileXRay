#include <windows.h>
#include "resource.h"
#include "version.h"
#include "../FileXRayFile/resource.h"

#pragma code_page(65001)

LANGUAGE LANG_NEUTRAL, SUBLANG_NEUTRAL

VS_VERSION_INFO VERSIONINFO
FILEVERSION FX_VERSION
PRODUCTVERSION FX_VERSION
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
FILEFLAGS VS_FF_DEBUG
#else
FILEFLAGS 0x0L
#endif
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_DLL
FILESUBTYPE VFT2_UNKNOWN
BEGIN
	BLOCK "StringFileInfo"
	BEGIN
		BLOCK "000004b0"
		BEGIN
			VALUE "CompanyName", FX_COMPANY "\0"
			VALUE "FileDescription", FX_FILEDESC "\0"
			VALUE "FileVersion", FX_VERSION_STR "\0"
			VALUE "InternalName", FX_INTERNALNAME "\0"
			VALUE "LegalCopyright", FX_COPYRIGHT "\0"
			VALUE "OriginalFilename", FX_ORIGINALNAME "\0"
			VALUE "ProductName", FX_PRODUCT "\0"
			VALUE "ProductVersion", FX_VERSION_STR "\0"
		END
	END
	BLOCK "VarFileInfo"
	BEGIN
		VALUE "Translation", 0x0000, 1200
	END
END

IDR_FILEXRAY_MAGIC_MGC RCDATA "../FileXRayFile/magic/magic.mgc"

LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US

IDD_FILEXRAY_PAGE DIALOGEX 0, 0, 227, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI"
BEGIN
	GROUPBOX        "File", IDC_FILE_GROUP, 7, 7, 213, 43
	EDITTEXT        IDC_FILE_TYPE, 17, 20, 197, 21, ES_MULTILINE | ES_READONLY | ES_AUTOHSCROLL | WS_BORDER | WS_TABSTOP

	GROUPBOX        "Hash", IDC_HASH_GROUP, 7, 55, 213, 135
	CONTROL         "MD5", IDC_HASH_MD5, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 17, 72, 42, 10
	CONTROL         "SHA1", IDC_HASH_SHA1, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 82, 72, 45, 10
	CONTROL         "CRC32", IDC_HASH_CRC32, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 147, 72, 52, 10
	CONTROL         "CRC64", IDC_HASH_CRC64, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 17, 86, 52, 10
	CONTROL         "SHA256", IDC_HASH_SHA256, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 82, 86, 62, 10
	PUSHBUTTON      "Calculate", IDC_HASH_START, 17, 102, 60, 14
	PUSHBUTTON      "Copy", IDC_HASH_COPY, 154, 102, 60, 14
	CONTROL         "", IDC_HASH_PROGRESS, "msctls_progress32", WS_BORDER, 17, 122, 197, 10
	LTEXT           "Ready.", IDC_HASH_STATUS, 17, 136, 197, 8
	EDITTEXT        IDC_HASH_RESULT, 17, 148, 197, 34, ES_MULTILINE | ES_READONLY | ES_AUTOHSCROLL | ES_AUTOVSCROLL | WS_VSCROLL | WS_BORDER | WS_TABSTOP

	GROUPBOX        "Extension", IDC_EXTENSION_GROUP, 7, 194, 213, 18
END

STRINGTABLE
BEGIN
	IDS_PAGE_TITLE                 "FileXRay"
	IDS_HASH_STATUS_READY          "Ready."
	IDS_HASH_STATUS_CANCELED       "Canceled."
	IDS_HASH_STATUS_FAILED_FORMAT  "Failed: 0x%08lx"
	IDS_HASH_SELECT_ONE            "Select at least one hash algorithm."
	IDS_HASH_STATUS_CALCULATING    "Calculating..."
	IDS_HASH_STATUS_COMPLETE       "Complete."
	IDS_HASH_STATUS_TOO_LARGE      "Complete, but the result text was too large."
	IDS_FILETYPE_UNABLE_FORMAT     "Unable to identify file: 0x%08lx"
END

LANGUAGE LANG_CHINESE, SUBLANG_CHINESE_SIMPLIFIED

IDD_FILEXRAY_PAGE DIALOGEX 0, 0, 227, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI"
BEGIN
	GROUPBOX        "文件", IDC_FILE_GROUP, 7, 7, 213, 43
	EDITTEXT        IDC_FILE_TYPE, 17, 20, 197, 21, ES_MULTILINE | ES_READONLY | ES_AUTOHSCROLL | WS_BORDER | WS_TABSTOP

	GROUPBOX        "哈希", IDC_HASH_GROUP, 7, 55, 213, 135
	CONTROL         "MD5", IDC_HASH_MD5, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 17, 72, 42, 10
	CONTROL         "SHA1", IDC_HASH_SHA1, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 82, 72, 45, 10
	CONTROL         "CRC32", IDC_HASH_CRC32, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 147, 72, 52, 10
	CONTROL         "CRC64", IDC_HASH_CRC64, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 17, 86, 52, 10
	CONTROL         "SHA256", IDC_HASH_SHA256, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 82, 86, 62, 10
	PUSHBUTTON      "计算", IDC_HASH_START, 17, 102, 60, 14
	PUSHBUTTON      "复制", IDC_HASH_COPY, 154, 102, 60, 14
	CONTROL         "", IDC_HASH_PROGRESS, "msctls_progress32", WS_BORDER, 17, 122, 197, 10
	LTEXT           "就绪。", IDC_HASH_STATUS, 17, 136, 197, 8
	EDITTEXT        IDC_HASH_RESULT, 17, 148, 197, 34, ES_MULTILINE | ES_READONLY | ES_AUTOHSCROLL | ES_AUTOVSCROLL | WS_VSCROLL | WS_BORDER | WS_TABSTOP

	GROUPBOX        "扩展", IDC_EXTENSION_GROUP, 7, 194, 213, 18
END

STRINGTABLE
BEGIN
	IDS_PAGE_TITLE                 "FileXRay"
	IDS_HASH_STATUS_READY          "就绪。"
	IDS_HASH_STATUS_CANCELED       "已取消。"
	IDS_HASH_STATUS_FAILED_FORMAT  "失败：0x%08lx"
	IDS_HASH_SELECT_ONE            "请选择至少一种哈希算法。"
	IDS_HASH_STATUS_CALCULATING    "正在计算..."
	IDS_HASH_STATUS_COMPLETE       "完成。"
	IDS_HASH_STATUS_TOO_LARGE      "已完成，但结果文本过大。"
	IDS_FILETYPE_UNABLE_FORMAT     "无法识别文件：0x%08lx"
END

