STRINGTABLE
BEGIN
	IDS_PAGE_TITLE                 "FileXRay"
	IDS_HASH_STATUS_READY          "就緒。"
	IDS_HASH_STATUS_CANCELED       "已取消。"
	IDS_HASH_STATUS_FAILED_FORMAT  "失敗：0x%08lx"
